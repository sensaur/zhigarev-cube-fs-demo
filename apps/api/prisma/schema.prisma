generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
}

model RequestLog {
  id             String   @id @default(cuid())
  method         String   @db.VarChar(10)
  path           String
  statusCode     Int
  responseTimeMs Int
  ip             String?
  userAgent      String?
  queryParams    String?
  contentLength  Int?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([statusCode])
}
