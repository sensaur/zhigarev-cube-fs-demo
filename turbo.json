{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "env": ["DATABASE_URL"]
    },
    "test:verbose": {
      "env": ["DATABASE_URL"]
    },
    "typecheck": {}
  }
}
