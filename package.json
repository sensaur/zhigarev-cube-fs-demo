{
  "name": "cube-draft",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:push": "pnpm --filter api prisma:push",
    "db:migrate": "pnpm --filter api prisma:migrate"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "turbo": "^2.9.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/engines", "esbuild", "prisma"]
  }
}
